{
  "name": "dofus-road",
  "productName": "Dofus Road",
  "version": "0.0.1",
  "private": false,
  "description": "Dofus Road - A tool to help you plan your Dofus journey.",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "Théo Liberman",
    "email": "liberman.theo@gmail.com"
  },
  "exports": "./src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "typecheck": "tsc --noEmit",
    "tag": "node -e \"const { execSync } = require('child_process'); const version = require('./package.json').version; const tag = 'v' + version; try { execSync('git rev-parse --verify ' + tag, { stdio: 'pipe' }); console.error('Git tag ' + tag + ' already exists.'); process.exit(1); } catch (error) { execSync('git tag ' + tag, { stdio: 'inherit' }); console.log('Created Git tag ' + tag + '.'); }\""
  },
  "main": ".vite/build/main.js",
  "devDependencies": {
    "@electron-forge/cli": "^8.0.0-alpha.10",
    "@electron-forge/maker-deb": "^8.0.0-alpha.10",
    "@electron-forge/maker-rpm": "^8.0.0-alpha.10",
    "@electron-forge/maker-squirrel": "^8.0.0-alpha.10",
    "@electron-forge/maker-zip": "^8.0.0-alpha.10",
    "@electron-forge/plugin-auto-unpack-natives": "^8.0.0-alpha.10",
    "@electron-forge/plugin-fuses": "^8.0.0-alpha.10",
    "@electron-forge/plugin-vite": "^8.0.0-alpha.10",
    "@electron-forge/publisher-github": "^8.0.0-alpha.10",
    "@electron/fuses": "^2.1.3",
    "@types/electron-squirrel-startup": "^1.0.2",
    "electron": "43.1.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.73.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
